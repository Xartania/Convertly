json.output:
[file]
category = "output"
type = { from: "csv", to: "json" }

[variables]
cells = { name: "cells", need: ["rows"], format: "  \"rows[index_header]{}\"(,)!"}
content = { name: "content", need: ["headers"], format: "  \"{headers{index_header}}\": [\n{cells}\n  ](,)!"}

[format]
file = "\{\n  {content}\n  \}"

{
  "header1": [
      row1.cell1,
      row2.cell1,
      ...
  ],
  "header2": [
      row1.cell2,
      row2.cell2,
      ...
  ]
}

// Format
{var} = value here
var{} = for each value (if tow var use var1{} & var2{} stop at the shortest one unless limits is set to true thent the the short ones will be empty)

var{} independant index
var{<counter_name>}
var[<counter_name>] use the x element of the variables (on error or out of bounds, display a blank, dosen't affect limit, var{} or counter)
the counter is global to every variables, only incremented by the higgest parent

(<string>)! -> displayed not on the last print
!(<string>) -> displayed not on the first print
!(<string>)! -> displayed not on the first & last print
(<string>)^ -> displayed only on the last print
^(<string>) -> displayed only on the first print
^(<string>)^ -> displayed only on the first & last print

// need
list of the variables needed for the format
if one of the needed variables dosen't exist, the whole format is replaced by a blank space ""

// Limit (enable or disable the limit for the deroulement of var{})
none -> false
limit: true
limit: false
