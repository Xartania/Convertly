#!/usr/bin/env sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
BACKEND_DIR=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)

export JAVA_HOME="$BACKEND_DIR/.tools/jdk-21.0.11+10"
export PATH="$JAVA_HOME/bin:$BACKEND_DIR/.tools/apache-maven-3.9.16/bin:$PATH"

exec "$BACKEND_DIR/.tools/apache-maven-3.9.16/bin/mvn" \
  -Dmaven.repo.local="$BACKEND_DIR/.tools/m2/repository" \
  "$@"
